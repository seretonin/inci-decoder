{
  "manifest_version": 3,
  "name": "INCI Beauty Decoder Overlay",
  "version": "1.0",
  "description": "Displays ingredient descriptions, ratings, and warnings from INCIDecoder on Lila Beauty product pages.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://lilabeauty.com.au/*",
    "https://incidecoder.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lilabeauty.com.au/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "INCI Decoder"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
